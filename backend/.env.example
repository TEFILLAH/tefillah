# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=tefilah

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Admin Secret (for creating first admin)
ADMIN_SECRET=tefilah-admin-secret-2024

# LLM Configuration — choose provider: gemini (recommended) | openrouter | ollama
LLM_PROVIDER=gemini

# Google Gemini (recommended — free tier, fast, multilingual)
# Get API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama (fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# Email Configuration (Resend)
RESEND_API_KEY=
SENDER_EMAIL=admin@tefillah.in

# Firebase Configuration (for Google sign-in)
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=

# OpenRouter API (legacy fallback, optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# CORS - comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
