# Development Backend URL
EXPO_PUBLIC_BACKEND_URL=http://localhost:8001

# Production Setup Instructions:
# When deploying to production (e.g. using EAS Build or Expo export), set the
# EXPO_PUBLIC_BACKEND_URL environment variable to your live backend domain via the
# EAS configuration or your CI/CD setup. 
# Example: EXPO_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# Firebase Configuration (required for Google/Apple sign-in)
# Get these from Firebase Console > Project Settings > General > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth Web Client ID (required for native mobile Google Sign-In)
# Get this from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Select the "Web application" type client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
