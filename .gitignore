# =============================================================================
# Tefillah monorepo .gitignore
# Backend (FastAPI) + frontend (Expo/React Native) + tefillah-web (Vite/React)
# =============================================================================

# ---- Secrets & credentials — NEVER commit --------------------------------
# real env files (the *.example templates below are kept)
.env
**/.env
.env.local
**/.env.local
.env.*.local
**/.env.*.local
# Firebase Admin service-account private key (backend / EB bundle / deploy dir)
firebase-credentials.json
**/firebase-credentials.json
# generic service-account / secret key material
*serviceAccount*.json
**/service-account*.json
*.pem
*.p8
*.p12
*.keystore
*.jks
!**/debug.keystore.example

# keep the documented templates so the repo is runnable
!.env.example
!**/.env.example

# ---- Elastic Beanstalk deploy artifacts (these ZIPs bundle secrets!) ------
_eb_build/
tefillah-api*.zip
*.zip

# ---- Node -----------------------------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ---- Python / backend -----------------------------------------------------
venv/
**/venv/
.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
# stray pip-redirect junk file
backend/=*

# ---- Expo / React Native (android/ & ios/ are generated by prebuild) ------
.expo/
**/.expo/
.expo-shared/
frontend/android/
frontend/ios/
*.orig.*
web-build/
**/.metro-cache/
.metro-health-check*

# ---- Web build outputs (Vite) ---------------------------------------------
dist/
**/dist/
dev-dist/
**/dev-dist/
.vite/

# ---- Logs / caches --------------------------------------------------------
*.log
logs/
.cache/
.turbo/

# ---- OS / editor ----------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
